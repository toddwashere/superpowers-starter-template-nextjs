# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter_dev

# Better Auth (dashboard)
BETTER_AUTH_URL=http://localhost:4000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:4000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:4000
NEXT_PUBLIC_WWW_URL=http://localhost:4001

# Public API (base URL, no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4002

# Public MCP (base URL, no trailing slash — port is parsed from this URL)
NEXT_PUBLIC_MCP_URL=http://localhost:4003

# OAuth (optional — app works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Email (Resend) — optional in development, required in production
# Get your API key at https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxx
# EMAIL_FROM="App Name <noreply@yourdomain.com>"
