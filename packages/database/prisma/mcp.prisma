model McpToolCallLog {
  id        String   @id @default(cuid())
  toolName  String
  authKind  String
  userId    String?
  orgId     String?
  clientId  String?
  keyId     String?
  success   Boolean
  errorCode String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([clientId])
  @@index([createdAt])
  @@map("mcpToolCallLog")
}
